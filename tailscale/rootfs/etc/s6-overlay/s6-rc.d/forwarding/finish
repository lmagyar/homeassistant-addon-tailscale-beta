#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant Community App: Tailscale
# Remove forwarding
# ==============================================================================

declare from_address_ipv4 from_address_ipv6

# In case of non userspace networking, remove the forwarding from tailnet to host
function remove_forwarding() {
  local cmd="${1}"
  local chain="${2}"
  local ip_version="${3}"
  local address_bits="${4}"
  local from_address="${5}"
  local to_address
  local name="${6}"

  if bashio::var.has_value "${from_address}"; then
    for to_address in $( \
      ${cmd} -t nat -S "${chain}" \
      | { grep -E "^-A ${chain} -d ${from_address}/${address_bits} -j DNAT --to-destination \S+$" || true ;} \
      | sed -nr 's/^.*?--to-destination\s(\S+)$/\1/p')
    do
      bashio::log.info "Removing the forwarding for ${name} connections from ${from_address} to ${to_address} (${ip_version})"
      if ! ${cmd} -t nat -D "${chain}" -d "${from_address}" -j DNAT --to-destination "${to_address}"; then
        bashio::log.warning "Removing forwarding for ${name} connections is unsuccessful (${ip_version})"
      fi
    done
  fi
}

# Tailscale's IP addresses
if ! from_address_ipv4=$(/opt/tailscale ip -4); then
  bashio::log.warning "Failed to retrieve Tailscale's IPv4 address"
fi
if ! from_address_ipv6=$(/opt/tailscale ip -6); then
  bashio::log.warning "Failed to retrieve Tailscale's IPv6 address"
fi

remove_forwarding "iptables" "PREROUTING" "IPv4" "32" "${from_address_ipv4-}" "incoming"
remove_forwarding "ip6tables" "PREROUTING" "IPv6" "128" "${from_address_ipv6-}" "incoming"
remove_forwarding "iptables" "OUTPUT" "IPv4" "32" "${from_address_ipv4-}" "local"
remove_forwarding "ip6tables" "OUTPUT" "IPv6" "128" "${from_address_ipv6-}" "local"
